{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18790,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true,
      "basePath": "/",
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/mnt/openclaw/workspace"
    }
  }
}
